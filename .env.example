# QuantSolo 环境变量示例
# 复制为 .env 并填写真实值
# cp .env.example .env

# ─── 数据根目录 ────────────────────────────────────────────────────────────────
# 本地 Parquet / SQLite 数据存放根路径（开发默认即可）
DATA_ROOT=./data

# SQLite 数据库路径（开发/回测）
DB_PATH=./db/quant.db

# ─── 运行输出 ─────────────────────────────────────────────────────────────────
# E2E 报告写入目录
RUN_DIR=./run

# ─── 迅投 QMT（实盘专用，纸面交易留空即可）────────────────────────────────────
# XT_ACCOUNT_ID=
# XT_ACCOUNT_TYPE=STOCK
# XT_SERVER_HOST=127.0.0.1
# XT_SERVER_PORT=58610

# ─── 告警 Webhook（可选）────────────────────────────────────────────────────────
# ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=XXXX
# ALERT_WEBHOOK_TYPE=wechat_work   # wechat_work | feishu | slack

# ─── 研究数据库（可选，默认同 DB_PATH）────────────────────────────────────────
# RESEARCH_DB_PATH=./db/research.db

# ─── 日志级别 ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── 并发与限流 ──────────────────────────────────────────────────────────────
# 因子计算并行线程数（0 = CPU 核数）
FACTOR_WORKERS=0

# ─── 环境标记 ─────────────────────────────────────────────────────────────────
# development | staging | production
QUANT_ENV=development
